/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    hillerlab/longread Nextflow config file
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
   * longread — simulate PacBio Iso-Seq reads at scale (Nextflow DSL2).
----------------------------------------------------------------------------------------
*/

cleanup = false
workDir = 'work'

/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    MANIFEST
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

manifest {
    name            = 'hillerlab/longread'
    author          = 'Alejandro Gonzales-Irribarren, Michael Hiller'
    homePage        = 'https://github.com/hillerlab/longread'
    description     = "simulate PacBio Iso-Seq reads at scale"
    mainScript      = 'src/main.nf'
    defaultBranch   = 'master'
    nextflowVersion = '!>=24.10.5'
    version         = '0.0.1'
}

validation {
    help {
        enabled = true
        command = "nextflow run main.nf -profile <docker/singularity/.../institute>"
        fullParameter = "help_full"
        showHiddenParameter = "show_hidden"
    }
}


/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    DEFAULT PARAMETER VALUES
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

params {
    // ---- Required inputs ---------------------------------------------------------------
    bed                        = null
    transcript_gene            = null
    sequence                   = null      // genome .fa/.fa.gz/.2bit
    outdir                     = 'results'
    prefix                     = 'simulation'

    // ---- Determinism / resources -------------------------------------------------------
    seed                       = 42

    // ---- Alternative-isoform generation (mutually exclusive count modes) ---------------
    new_isoforms_per_gene      = null      // fixed count; null => Poisson mode below
    mean_new_isoforms_per_gene = 1.0
    max_new_isoforms_per_gene  = 5
    event_weights              = 'donor=1,acceptor=1,skip=1,retention=1,truncation=1'
    max_event_attempts         = 100
    minimum_transcript_length  = 100

    // ---- Fusions -----------------------------------------------------------------------
    fusion_count               = 0
    min_fusion_intron          = 1
    max_fusion_distance        = null      // unlimited
    fusion_expression_scale    = 1.0

    // ---- Expression --------------------------------------------------------------------
    total_molecules            = 100000
    alpha                      = 4.0

    // ---- PBSIM3 ------------------------------------------------------------------------
    pbsim_method               = 'errhmm'  // errhmm | qshmm
    // Entry script lives in src/, so projectDir is <repo>/src; the repo root is one level up.
    pbsim_model                = "${projectDir}/../assets/pbsim_models/ERRHMM-SEQUEL.model"
    pass_count                 = 10
    pbsim_chunks               = 1
    pbsim_machine              = "SEQUEL"
    pbsim_mode                 = "wgs" // wgs | trans
    pbsim_chunks               = 10

    // ---- Optional stages ---------------------------------------------------------------
    do_ccs                     = false
    do_isoseq_cluster          = false
    ccs_chunk                  = 10
    isoseq_min_rq              = 0.95      // CCS minimum predicted read quality

    // ---- Pipeline behaviour ------------------------------------------------------------
    publish_dir_mode           = 'copy'
    help                       = false
    trace_report_suffix          = new java.util.Date().format( 'yyyy-MM-dd_HH-mm-ss')  // Config options
}

/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    EXTENDING PROCESS DEFINITIONS AND ARGUMENTS
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

process {

    withName: '.*:CHROMSIZE' {
        publishDir = [
            path: { "${params.outdir}/01_CHROMSIZE" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: '.*:LONGREAD_PREPARE' {
        publishDir = [
            path: { "${params.outdir}/02_LONGREAD_PREPARE" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: '.*:XLOCI_EXON' {
        publishDir = [
            path: { "${params.outdir}/03_XLOCI" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: '.*:LONGREAD_PBSIM' {
        publishDir = [
            path: { "${params.outdir}/04_LONGREAD_PBSIM" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: '.*:LONGREAD_SPLIT' {
        publishDir = [
            path: { "${params.outdir}/04_LONGREAD_SPLIT" },
            mode: 'symlink',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: '.*:PBSIM3' {
        publishDir = [
            path: { "${params.outdir}/04_PBSIM3/BAM" },
            mode: 'symlink',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            pattern: '*.bam'
        ]
    }

    withName: '.*:PUBLISH_MAF' {
        publishDir = [
            path: { "${params.outdir}/04_PBSIM3/MAF" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            pattern: '*.maf'
        ]
    }

    withName: '.*:PUBLISH_REF_MAP' {
        publishDir = [
            path: { "${params.outdir}/04_PBSIM3/MAP" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            pattern: '*.tsv'
        ]
    }

    withName: '.*:SIMULATE_SUBREADS:NORMALIZE_PACBIO_RG' {
        publishDir = [
            path: { "${params.outdir}/05_MERGE_SUBREADS" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('zmw_map.tsv') ? filename : null }
        ]
    }

    withName: '.*:SIMULATE_SUBREADS:PBMERGE' {
        publishDir = [
            path: { "${params.outdir}/05_MERGE_SUBREADS" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: '.*:PUBLISH_CCS' {
        publishDir = [
            path: { "${params.outdir}/06_PBCCS" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: '.*:PUBLISH_CLUSTERED' {
        publishDir = [
            path: { "${params.outdir}/07_ISOSEQ_CLUSTER" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: '.*:BAM_TO_FA' {
        publishDir = [
            path: { "${params.outdir}/08_BAM_TO_FA" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
}

/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    EXECUTOR/PROFILES CONFIG
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

profiles {
     slurm {
        process {
            executor        = 'slurm'
            queue           = 'batch'
            scratch         = true
            stageInMode     = 'symlink'
            stageOutMode    = 'rsync'
            queue          = { task.time <= 24.h ? 'batch' : 'long' }
            clusterOptions = '--signal=USR2@180 --export=ALL,SLURM_SKIP_EPILOG=1'
            withName: '.*:PBCCS|.*:TRANSLATION|.*:TRANSAID|.*:RNASAMBA|.*:NETSTART|.*:APARENT_PREDICT' {
                array = 500
            }
        }
        executor {
            queueSize         = 10000
            killBatchSize     = 1000000
            pollInterval      = '10 s'      // internal task-monitor tick (no SLURM RPC)
            queueStatInterval = '1 min'     // squeue cadence — halves RPC pressure
            submitRateLimit   = '5000/30sec' // max concurrent submits per node
            exitReadTimeout   = '5 min'    // tolerate slow .exitcode propagation; lets retry fire on ghosts
        }
    }   

    debug {
        dumpHashes              = true
        process.beforeScript    = 'echo $HOSTNAME'
        cleanup                 = false
        nextflow.enable.configProcessNamesValidation = true
    }

    conda {
        conda.enabled           = true
        docker.enabled          = false
        singularity.enabled     = false
        podman.enabled          = false
        shifter.enabled         = false
        charliecloud.enabled    = false
        conda.channels          = ['conda-forge', 'bioconda']
        apptainer.enabled       = false
    }

    mamba {
        conda.enabled           = true
        conda.useMamba          = true
        conda.channels          = ['conda-forge', 'bioconda']
        docker.enabled          = false
        singularity.enabled     = false
        podman.enabled          = false
        shifter.enabled         = false
        charliecloud.enabled    = false
        apptainer.enabled       = false
    }

    docker {
        docker.enabled          = true
        conda.enabled           = false
        singularity.enabled     = false
        podman.enabled          = false
        shifter.enabled         = false
        charliecloud.enabled    = false
        apptainer.enabled       = false
        docker.runOptions       = '-u $(id -u):$(id -g)'
    }

    arm {
        docker.runOptions       = '-u $(id -u):$(id -g) --platform=linux/amd64'
        includeConfig 'conf/arm.config'
    }

    singularity {
        singularity.enabled     = true
        singularity.autoMounts  = true
        conda.enabled           = false
        docker.enabled          = false
        podman.enabled          = false
        shifter.enabled         = false
        charliecloud.enabled    = false
        apptainer.enabled       = false
    }

    podman {
        podman.enabled          = true
        conda.enabled           = false
        docker.enabled          = false
        singularity.enabled     = false
        shifter.enabled         = false
        charliecloud.enabled    = false
        apptainer.enabled       = false
    }

    shifter {
        shifter.enabled         = true
        conda.enabled           = false
        docker.enabled          = false
        singularity.enabled     = false
        podman.enabled          = false
        charliecloud.enabled    = false
        apptainer.enabled       = false
    }

    charliecloud {
        charliecloud.enabled    = true
        conda.enabled           = false
        docker.enabled          = false
        singularity.enabled     = false
        podman.enabled          = false
        shifter.enabled         = false
        apptainer.enabled       = false
    }

    apptainer {
        apptainer.enabled       = true
        apptainer.autoMounts    = true
        conda.enabled           = false
        docker.enabled          = false
        singularity.enabled     = false
        podman.enabled          = false
        shifter.enabled         = false
        charliecloud.enabled    = false
    }
    wave {
        apptainer.ociAutoPull   = true
        singularity.ociAutoPull = true
        wave.enabled            = true
        wave.freeze             = true
        wave.strategy           = 'conda,container'
    }

    gitpod {
        executor.name           = 'local'
        executor.cpus           = 4
        executor.memory         = 8.GB
        process {
            resourceLimits = [
                memory: 8.GB,
                cpus  : 4,
                time  : 1.h
            ]
        }
    }

    gpu {
        docker.runOptions       = '-u $(id -u):$(id -g) --gpus all'
        apptainer.runOptions    = '--nv'
        singularity.runOptions  = '--nv'
    }

    test {
        params.bed = "${projectDir}/../tests/data/mini.bed"
        params.transcript_gene = "${projectDir}/../tests/data/mini.transcript_gene.tsv"
        params.sequence = "${projectDir}/../tests/data/genome.fa"
        params.outdir = "${projectDir}/../tests/data/results"
        params.prefix = "test"

        params.seed = 42

        params.new_isoforms_per_gene = null
        params.mean_new_isoforms_per_gene = 1.0
        params.max_new_isoforms_per_gene = 5
        params.event_weights = "donor=1,acceptor=1,skip=1,retention=1,truncation=1"
        params.max_event_attempts = 100
        params.minimum_transcript_length = 0

        params.fusion_count = 0
        params.min_fusion_intron = 1
        params.max_fusion_distance = null
        params.fusion_expression_scale = 1.0

        params.total_molecules = 100000
        params.alpha = 4.0

        params.pbsim_method = "errhmm"
        params.pbsim_model = "${projectDir}/../assets/pbsim_models/ERRHMM-SEQUEL.model"
        params.pass_count = 10
        params.pbsim_chunks = 1
        params.pbsim_machine = "SEQUEL"
        params.pbsim_mode = "wgs"
        params.pbsim_chunks = 2

        params.do_ccs = true
        params.do_isoseq_cluster = true
        params.ccs_chunk = 10
        params.isoseq_min_rq = 0.95
    }
}

/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    PROCESS LABELS;
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

process {

    cpus   = { 1      * task.attempt }
    memory = { 6.GB   * task.attempt }
    time   = { 4.h    * task.attempt }

    errorStrategy = {
        (task.exitStatus in ((130..145) + 104 + 175)) ||
        (task.exitStatus in [null, Integer.MAX_VALUE])   ? 'retry' : 'finish'
    }
    maxRetries    = 5
    maxErrors     = '-1'

    // Single processes
    withLabel:process_single {
        cpus   = { 1                   }
        memory = { 6.GB * task.attempt }
        time   = { 4.h  * task.attempt }
    }

    // Low memory processes
    withLabel:process_low {
        cpus   = { 2     * task.attempt }
        memory = { 12.GB * task.attempt }
        time   = { 4.h   * task.attempt }
    }
    withLabel:custom_process_low {
        cpus   = { 4     * task.attempt }
        memory = { 10.GB * task.attempt }
        time   = { 4.h   * task.attempt }
    }
     withLabel:process_low_long {
        cpus   = { 4     * task.attempt }
        memory = { 16.GB * task.attempt }
        time   = { 10.h   * task.attempt }
    }

    // Medium memory processes
    withLabel:process_medium {
        cpus   = { 6     * task.attempt }
        memory = { 36.GB * task.attempt }
        time   = { 8.h   * task.attempt }
    }
    withLabel:process_medium_fast {
        cpus   = { 6     * task.attempt }
        memory = { 36.GB * task.attempt }
        time   = { 2.h   * task.attempt }
    }
    withLabel:process_medium_high_memory {
        cpus   = { 6 }
        memory = { 96.GB * task.attempt }
        time   = { 12.h }
    }

    withLabel:custom_process_medium {
        cpus   = { 6     * task.attempt }
        memory = { 64.GB * task.attempt }
        time   = { 12.h   * task.attempt }
    }

    // High memory processes
    withLabel:process_high {
        cpus   = { 12    * task.attempt }
        memory = { 72.GB * task.attempt }
        time   = { 16.h  * task.attempt }
    }
    withLabel:process_high_memory {
        memory = { 200.GB * task.attempt }
    }
    withLabel:process_high_fast {
        cpus   = { 12    * task.attempt }
        memory = { 72.GB * task.attempt }
        time   = { 2.h  * task.attempt }
    }
    withLabel:process_high_low_memory_fast {
        cpus   = { 12    * task.attempt }
        memory = { 16.GB * task.attempt }
        time   = { 2.h  * task.attempt }
    }
    withLabel:process_high_cpu {
        cpus   = { 16    * task.attempt }
        memory = { 16.GB * task.attempt }
        time   = { 2.h  * task.attempt }
    }


    // Long running processes
    withLabel:process_long {
        time   = { 20.h  * task.attempt }
    }

    // Strategies
    withLabel:error_ignore {
        errorStrategy = 'ignore'
    }
    withLabel:error_retry {
        errorStrategy = 'retry'
        maxRetries    = 2
    }

    // GPU
    withLabel: process_gpu {
        ext.use_gpu = { workflow.profile.contains('gpu') }
        accelerator = { workflow.profile.contains('gpu') ? 1 : null }
    }
}

// ══════════════════════════════════════════════════════════════════════════════
// Set the container image to use for all processes through use_container option.
// If not set, the default is to use the apptainer cache image for every module.
// To modify go to params.json and set 'use_container' to false.
// ══════════════════════════════════════════════════════════════════════════════

if (params.use_container) {
  process {
    withName: '.*' {
        container = System.getenv('NXF_CONTAINER_IMAGE') ?:
            'ghcr.io/hillerlab/longread:latest'
    }
  }
}

/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    REGISTRY CONFIG
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

// Set default registry for Apptainer, Docker, Podman, Charliecloud and Singularity independent of -profile
// Will not be used unless Apptainer / Docker / Podman / Charliecloud / Singularity are enabled
// Set to your registry if you have a mirror of containers
apptainer.registry    = 'quay.io'
docker.registry       = 'quay.io'
podman.registry       = 'quay.io'
singularity.registry  = 'quay.io'
charliecloud.registry = 'quay.io'

/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    ENVIRONMENT CONFIG
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

// Export these variables to prevent local Python/R libraries from conflicting with those in the container
// The JULIA depot path has been adjusted to a fixed path `/usr/local/share/julia` that needs to be used for packages in the container.
// See https://apeltzer.github.io/post/03-julia-lang-nextflow/ for details on that. Once we have a common agreement on where to keep Julia packages, this is adjustable.

env {
    PYTHONNOUSERSITE = 1
    R_PROFILE_USER   = "/.Rprofile"
    R_ENVIRON_USER   = "/.Renviron"
    JULIA_DEPOT_PATH = "/usr/local/share/julia"
}

/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    BASH OPTIONS
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

// Set bash options
process.shell = [
    "bash",
    "-C",         // No clobber - prevent output redirection from overwriting files.
    "-e",         // Exit if a tool returns a non-zero status/exit code
    "-u",         // Treat unset variables and parameters as an error
    "-o",         // Returns the status of the last command to exit..
    "pipefail"    //   ..with a non-zero status or zero if all successfully execute
]


/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    REPORT PARAMETER VALUES
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

// Disable process selector warnings by default. Use debug profile to enable warnings.
nextflow.enable.configProcessNamesValidation = false

timeline {
    enabled = true
    file    = "${params.outdir}/PIPELINE_INFO/execution_timeline_${params.trace_report_suffix}.html"
}
report {
    enabled = true
    file    = "${params.outdir}/PIPELINE_INFO/execution_report_${params.trace_report_suffix}.html"
}
trace {
    enabled = true
    file    = "${params.outdir}/PIPELINE_INFO/execution_trace_${params.trace_report_suffix}.txt"
}
dag {
    enabled = true
    file    = "${params.outdir}/PIPELINE_INFO/pipeline_dag_${params.trace_report_suffix}.html"
}
